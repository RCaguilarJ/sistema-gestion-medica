<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /


    Header always set Access-Control-Allow-Origin "https://amdj.desingsgdl.app"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Signature, X-Source"
    Header always set Access-Control-Allow-Credentials "true"


    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]


    RewriteCond %{REQUEST_URI} ^/api/
    RewriteRule ^api/(.*)$ http://127.0.0.1:4000/api/$1 [P,L]


    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]


    RewriteRule ^ index.html [L]
</IfModule>


Options -Indexes